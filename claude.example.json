{
  "_comment": "Paste these two blocks into your ~/.claude.json under 'mcpServers'. Replace YOUR_EMAIL and YOUR_APP_PASSWORD with values from https://appleid.apple.com. Replace /path/to/icloud-mcp with where you cloned this repo.",
  "mcpServers": {
    "icloud-mail": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--with", "mcp", "python", "/path/to/icloud-mcp/mail_server.py"],
      "env": {
        "ICLOUD_USER": "YOUR_EMAIL@me.com",
        "ICLOUD_APP_PASSWORD": "YOUR_APP_PASSWORD",
        "SSL_CERT_FILE": "/etc/ssl/cert.pem"
      }
    },
    "icloud-cal": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--with", "caldav",
        "--with", "vobject",
        "--with", "mcp",
        "python", "/path/to/icloud-mcp/server.py"
      ],
      "env": {
        "ICLOUD_USER": "YOUR_EMAIL@me.com",
        "ICLOUD_APP_PASSWORD": "YOUR_APP_PASSWORD",
        "SSL_CERT_FILE": "/etc/ssl/cert.pem",
        "REQUESTS_CA_BUNDLE": "/etc/ssl/cert.pem"
      }
    }
  }
}
